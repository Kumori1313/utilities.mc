    "enchantments": {
      "source_a": "misode/mcmeta @ 1.21.3-data (dump of the game's own data files; 1.21+ enchantments are datapack-defined)",
      "source_b": "PrismarineJS/minecraft-data @ pc/1.21.1 (community dataset; 1.21.3 aliases to it)",
      "agreement": "210 field comparisons (weight, max_level, min_cost, max_cost, exclusive sets) across 42 enchantments, 0 disagreements",
      "note": "mcmeta declares exclusivity one-directionally; vanilla areCompatible() tests both sides, so exclusive_with here is the SYMMETRIC CLOSURE. A one-directional check against raw mcmeta data would wrongly allow e.g. channeling+riptide together."
    },
    "enchantability": {
      "source_a": "minecraft.wiki 'Enchanting table mechanics' revision 2754638 (2024-11-19), inside the 1.21.3 window",
      "source_b": "NOT YET INDEPENDENTLY CONFIRMED - see caveat",
      "caveat": "Single source lineage. The LIVE wiki lists Copper armor/tools, which do not exist in 1.21.3, so the current page has drifted past our pinned version; the pinned revision agrees with it on every non-copper value. That is a version check, not an independence check. Values are hardcoded in item properties (yarn field: enchantmentValue), not present in any data dump we could reach."
    }
  },
